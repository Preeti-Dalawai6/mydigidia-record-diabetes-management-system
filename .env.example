# Copy this file to .env and fill in your own values.
# Never commit your real .env file to version control.

# Flask
SECRET_KEY=change-this-to-a-long-random-string

# MySQL database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mydigidia_record

# Outgoing mail (used for password-reset OTP emails)
# For Gmail, create a 16-character App Password — do NOT use your normal password.
MAIL_SENDER_EMAIL=your-email@gmail.com
MAIL_SENDER_APP_PASSWORD=your-16-char-app-password
